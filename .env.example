# Required. Create a Clerk application and copy its API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional. A GitHub token raises the rate limit for the "paste a public repo"
# feature (the repo tree is read via the GitHub API). Locus works without it for
# small/medium public repos. Create one at https://github.com/settings/tokens
# (no scopes needed for public repos).
GITHUB_TOKEN=

# GitHub OAuth (optional — enables private repo access).
# Create an OAuth app at https://github.com/settings/developers
# Set the callback URL to https://your-domain.com/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Supabase (required for persistence, API keys, analytics).
# Create a project at https://supabase.com/dashboard and run the migration
# in supabase/migrations/001_initial_schema.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (optional — enables Pro tier billing).
# Create a product + price in Stripe Dashboard, then copy the keys.
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Public URLs (auto-detected on Vercel; set for local dev or self-hosting).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_REPO_URL=https://github.com/taranggoyal70/locus
